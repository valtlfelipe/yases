# Database and Redis configuration
DATABASE_URL=postgres://email:email@localhost:5432/email_service
REDIS_URL=redis://localhost:6379

# Email sending configuration
DISPOSABLE_BLOCKLIST_URL=https://raw.githubusercontent.com/disposable/disposable-email-domains/master/domains.txt
EMAIL_QUEUE_CONCURRENCY=10

# Dashboard auth (Better Auth)
# Create initial admin: cd apps/server && bun run create:admin admin@example.com yourpassword
BETTER_AUTH_SECRET=change-me-to-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:3000

# Secret for signing tokens (unsubscribe links, etc.) — min 32 chars
TOKEN_SECRET=change-me-to-at-least-32-random-characters
CREDENTIALS_ENCRYPTION_KEY=change-me-to-32-character-key
